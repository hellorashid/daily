{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Daily",
  "version": "0.1.4",
  "identifier": "lol.raz.daily",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Daily",
        "width": 420,
        "height": 520,
        "minWidth": 420,
        "minHeight": 520,
        "maxWidth": 420,
        "maxHeight": 520,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "fullscreen": false,
        "focus": false,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; base-uri 'none'; object-src 'none'; frame-ancestors 'none'; img-src 'self' asset: https://asset.localhost data:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost ws: wss: http: https:;"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIyMzVGNEIyNUVEREQ4QUQKUldTdDJOMWVzdlExc3RmRmRoSVZMbHdGNUViVjlPZEJ2ZWJrcmwralpoOUd2aDY5aUZJLzdXM0kK",
      "endpoints": [
        "https://github.com/hellorashid/daily/releases/latest/download/latest.json"
      ]
    }
  }
}
