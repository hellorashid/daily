# Preferred notarization path: App Store Connect API key
# Create an API key in App Store Connect > Users and Access > Integrations
# and point APPLE_API_KEY_PATH at the downloaded .p8 file.
APPLE_API_ISSUER=
APPLE_API_KEY=
APPLE_API_KEY_PATH=

# Optional override if the release script cannot auto-detect your Developer ID cert.
# APPLE_SIGNING_IDENTITY=Developer ID Application: Basic Studio Inc (UBWBPNVBAN)

# Updater private key used to sign Tauri updater bundles.
# TAURI_SIGNING_PRIVATE_KEY_PATH=$HOME/.tauri/daily-updater.key

# Alternative notarization path if you prefer Apple ID credentials instead:
# APPLE_ID=
# APPLE_PASSWORD=
# APPLE_TEAM_ID=
